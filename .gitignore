# Dependencies
node_modules/

# Build output
dist/

# sbom-sentinel output artifacts
artifacts/

# Environment — NEVER commit
.env

# Local config with real repo URLs (use examples/sbom-sentinel.config.json as template)
sbom-sentinel.config.json
.env.local

# Local deployment files — project-specific, generated per deployment
deploy/

# (deploy/ is gitignored; use examples/kubernetes/ as the starting template)
.env.*.local
.npmrc

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Testing
coverage/

# Logs
*.log
npm-debug.log*

# Cache
.cache/

# Secrets and keys
*.pem
*.key

# Claude Code — local settings and agent worktrees (personal — not shared)
.claude/settings.local.json
.claude/worktrees/

# SDD DevFlow local metadata (not part of sbom-sentinel)
.sdd-meta.json

# Local spec/onboarding docs (not part of the published package)
initialDocs/

# sbom-sentinel environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Token for cloning repositories via HTTPS.
# GitHub: use a Personal Access Token or Fine-grained token with repo read access.
# GitLab: use a Project/Group Access Token with read_repository scope.
# Bitbucket: use an App Password with Repositories Read permission.
GIT_TOKEN=your-token-here

# ── Optional — Git ────────────────────────────────────────────────────────────

# Git username injected into clone URLs (default: x-token-auth).
# For GitHub tokens use: x-token-auth
# For Bitbucket App Passwords use your Bitbucket username.
# GIT_USER=x-token-auth

# ── Optional — Slack ──────────────────────────────────────────────────────────

# Incoming webhook URL for Slack notifications.
# Create one at: https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/xxxx

# ── Optional — Email (SMTP) ───────────────────────────────────────────────────

# Requires: npm install nodemailer
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@example.com
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=alerts@example.com
# EMAIL_TO=security@example.com,devops@example.com

# ── Optional — Runtime overrides ─────────────────────────────────────────────

# Path to the config file (default: ./sbom-sentinel.config.json)
# SENTINEL_CONFIG=./sbom-sentinel.config.json

# Output directory for artifacts and reports (default: ./artifacts)
# SENTINEL_OUTPUT_DIR=./artifacts

# Scan only a specific repository by name
# SENTINEL_REPO=my-backend

# Log verbosity: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# sbom-sentinel — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env — it contains secrets

# ── Required (at least one token must be set for private repos) ───────────────
# Generic token — used as fallback when no platform-specific token is set
# GIT_TOKEN=your_token_here

# ── Optional: Platform-specific Git auth (takes priority over GIT_TOKEN) ──────
# GitHub — Personal Access Token (PAT) for github.com repositories
# GITHUB_TOKEN=your_github_pat_here
# GITHUB_USER=x-token-auth

# Bitbucket — App Password or Repository Access Token for bitbucket.org repos
# BITBUCKET_TOKEN=your_bitbucket_app_password_here
# BITBUCKET_USER=your_bitbucket_username

# ── Optional: Generic Git auth (fallback for other hosts or mixed setups) ─────
# GIT_USER=x-token-auth

# ── Optional: Slack notifications ─────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ── Optional: Email notifications (requires nodemailer) ───────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=your_smtp_password
# EMAIL_FROM=sbom-sentinel@example.com
# EMAIL_TO=security@example.com,devops@example.com

# ── Optional: Config overrides ────────────────────────────────────────────────
# Path to config file (default: ./sbom-sentinel.config.json)
# SENTINEL_CONFIG=./sbom-sentinel.config.json

# Path to output directory (overrides outputDir in config)
# SENTINEL_OUTPUT_DIR=./artifacts

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info
